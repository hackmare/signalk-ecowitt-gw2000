{
  "name": "signalk-ecowitt-gw2000",
  "version": "1.0.0",
  "description": "SignalK plugin for Ecowitt GW2000B with WS90 all-in-one weather station",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-weather",
    "signalk",
    "ecowitt",
    "gw2000",
    "ws90",
    "weather"
  ],
  "signalk": {
    "displayName": "Ecowitt GW2000B + WS90 Weather Station"
  },
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "babel-plugin-istanbul": "^8.0.0",
    "jest": "^29.7.0",
    "test-exclude": "^8.0.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "index.js"
    ]
  },
  "author": "Morgane Oger <m.oger@roitsystems.ca>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hackmare/signalk-ecowitt-gw2000.git"
  },
  "homepage": "https://github.com/hackmare/signalk-ecowitt-gw2000#readme",
  "bugs": {
    "url": "https://github.com/hackmare/signalk-ecowitt-gw2000/issues"
  },
  "signalk-plugin-enabled-by-default": false
}
